{
  "compilerOptions": {
    "target": "ES2024",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node"],
    "typeRoots": ["../../lab/node_modules/@types"],
    "paths": {
      "@testing-library/jest-dom/vitest": ["../../lab/node_modules/@testing-library/jest-dom/vitest"],
      "@testing-library/react": ["../../lab/node_modules/@testing-library/react"],
      "@testing-library/user-event": ["../../lab/node_modules/@testing-library/user-event"],
      "pixi.js": ["../../lab/node_modules/pixi.js"],
      "vitest": ["../../lab/node_modules/vitest"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
