{
  "compilerOptions": {
    "target": "ES2024",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@testing-library/jest-dom/vitest": ["../../lab/node_modules/@testing-library/jest-dom/vitest.d.ts"],
      "@testing-library/react": ["../../lab/node_modules/@testing-library/react/types/index.d.ts"],
      "pixi.js": ["../../lab/node_modules/pixi.js/lib/index.d.ts"],
      "react": ["../../lab/node_modules/@types/react/index.d.ts"],
      "react-dom/client": ["../../lab/node_modules/@types/react-dom/client.d.ts"],
      "react/jsx-runtime": ["../../lab/node_modules/@types/react/jsx-runtime.d.ts"],
      "vitest": ["../../lab/node_modules/vitest/dist/index.d.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
